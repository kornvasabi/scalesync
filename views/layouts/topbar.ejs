<div id="content-wrapper" class="d-flex flex-column">

            <div id="content">

                <nav class="navbar navbar-expand navbar-light bg-white topbar mb-4 static-top shadow">
                    <button id="sidebarToggleTop" class="btn btn-link d-md-none rounded-circle mr-3">
                        <i class="fa fa-bars"></i>
                    </button>
                    
                    <ul class="navbar-nav ml-auto">
                        <div class="topbar-divider d-none d-sm-block"></div>
						<li class="nav-item dropdown no-arrow mx-1">
							<a class="nav-link dropdown-toggle" href="#" id="languageDropdown" role="button"
								data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
								
								<% if (currentLang === 'en') { %>
									<span class="mr-2 d-none d-lg-inline text-gray-600 small">🇬🇧 English</span>
								<% } else { %>
									<span class="mr-2 d-none d-lg-inline text-gray-600 small">🇹🇭 ไทย</span>
								<% } %>
								
								<i class="fas fa-globe fa-fw"></i>
							</a>
							
							<div class="dropdown-menu dropdown-menu-right shadow animated--grow-in"
								aria-labelledby="languageDropdown">
								
								<a class="dropdown-item btn-change-lang <%= currentLang === 'th' ? 'active' : '' %>" 
								   href="<%= baseUrl %>/change-lang/th">
									🇹🇭 ภาษาไทย
								</a>
								
								<a class="dropdown-item btn-change-lang <%= currentLang === 'en' ? 'active' : '' %>" 
								   href="<%= baseUrl %>/change-lang/en">
									🇬🇧 English
								</a>
								
							</div>
						</li>
						<div class="topbar-divider d-none d-sm-block"></div>
                        <li class="nav-item dropdown no-arrow">
                            <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" data-toggle="dropdown">
                                <% if (locals.user) { %>
									<span class="mr-2 d-none d-lg-inline text-gray-600 small font-weight-bold">
										<%= user.fullname %> 
										
										<% if (user.group_name) { %>
											<small class="text-primary">(<%= user.group_name %>)</small>
										<% } %>
									</span>
								<% } else { %>
									<span class="mr-2 d-none d-lg-inline text-gray-600 small">Guest</span>
								<% } %>
								
								<span class="mr-2 d-none d-lg-inline text-gray-600 small font-weight-bold">
									<span class="badge badge-info ml-1"><%= user.branch_name || 'ไม่ระบุสาขา' %></span>
								</span>
                                <img class="img-profile rounded-circle" src="<%= baseUrl %>/img/undraw_profile.svg">
                            </a>
                            <div class="dropdown-menu dropdown-menu-right shadow animated--grow-in" aria-labelledby="userDropdown">
                                <a class="dropdown-item" href="#" data-toggle="modal" data-target="#logoutModal">
                                    <i class="fas fa-sign-out-alt fa-sm fa-fw mr-2 text-gray-400"></i>
                                    Logout
                                </a>
                            </div>
                        </li>
                    </ul>
					
                </nav>
				<style>
					/* ล็อกหน้าจอหลักไม่ให้เลื่อน */
					body { overflow: hidden !important; } 

					/* สร้างกล่องเลื่อนเฉพาะเนื้อหา */
					.my-custom-scroll {
						/* หัก Topbar และ Footer ออก เพื่อให้พอดีจอเป๊ะๆ */
						height: calc(100vh - 170px);
						overflow-y: auto; 
						overflow-x: hidden;
						padding-top: 15px;
						padding-bottom: 50px;
					}

					/* แต่งสี Scrollbar ให้เล็กและดูโมเดิร์น (สำหรับ Chrome/Edge) */
					.my-custom-scroll::-webkit-scrollbar { width: 8px; }
					.my-custom-scroll::-webkit-scrollbar-track { background: transparent; }
					.my-custom-scroll::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
					.my-custom-scroll::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
				</style>