<%- include('./layouts/header') %>
<%- include('./layouts/sidebar') %>

<div id="content-wrapper" class="d-flex flex-column">
    <div id="content">

        <%- include('./layouts/topbar') %>

        <div class="container-fluid pb-4">
            <style>
                /* เมนูด่วนเยอะ: ไม่ให้การ์ดสูงเกินจอจนต้องหา footer ยาก — เลื่อนในกล่องได้ */
                .dashboard-quick-links {
                    max-height: min(50vh, 420px);
                    overflow-y: auto;
                }
            </style>

            <div class="d-sm-flex align-items-center justify-content-between mb-4">
                <h1 class="h3 mb-0 text-gray-800"><%= __('dashboard.page_title') %></h1>
                <% if (canReport) { %>
                <a href="<%= baseUrl %>/report_issues" class="d-none d-sm-inline-block btn btn-sm btn-primary shadow-sm">
                    <i class="fas fa-download fa-sm text-white-50"></i> <%= __('dashboard.export_report') %>
                </a>
                <% } %>
            </div>

            <% const u = session.user || {}; %>
            <div class="alert alert-success shadow-sm mb-4" role="alert">
                <h4 class="alert-heading"><i class="fas fa-smile-beam"></i> <%= __('dashboard.welcome_title') %></h4>
                <p class="mb-2"><%= __('dashboard.welcome_lead', u.fullname || __('dashboard.not_specified')) %></p>
                <hr>
                <p class="mb-1 text-sm">
                    <i class="fas fa-user-shield text-success"></i>
                    <strong><%= __('dashboard.role_label') %>:</strong> <%= u.group_name || __('dashboard.not_specified') %>
                </p>
                <p class="mb-1 text-sm">
                    <i class="fas fa-store text-success"></i>
                    <strong><%= __('dashboard.branch_label') %>:</strong> <%= u.branch_name || __('dashboard.not_specified') %>
                </p>
                <p class="mb-0 text-sm">
                    <i class="fas fa-sitemap text-success"></i>
                    <strong><%= __('dashboard.dept_label') %>:</strong> <%= u.dept_name || __('dashboard.not_specified') %>
                </p>
            </div>

            <% if (stats && stats.length > 0) { %>
            <div class="row">
                <% stats.forEach(function(stat) { %>
                <div class="col-xl-3 col-md-6 mb-4">
                    <div class="card border-left-<%= stat.border %> shadow h-100 py-2">
                        <div class="card-body">
                            <div class="row no-gutters align-items-center">
                                <div class="col mr-2">
                                    <div class="text-xs font-weight-bold text-<%= stat.border %> text-uppercase mb-1">
                                        <%= stat.key === 'users' ? __('dashboard.stat_users') : __('dashboard.stat_branches') %>
                                    </div>
                                    <div class="h5 mb-0 font-weight-bold text-gray-800">
                                        <%= stat.total %>
                                        <span class="text-sm font-weight-normal text-muted">
                                            <%= stat.key === 'users' ? __('dashboard.unit_people') : __('dashboard.unit_branches') %>
                                        </span>
                                    </div>
                                </div>
                                <div class="col-auto">
                                    <i class="fas <%= stat.icon %> fa-2x text-gray-300"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <% }); %>
            </div>
            <% } else { %>
            <div class="alert alert-light border shadow-sm mb-4" role="alert">
                <h6 class="font-weight-bold text-gray-800 mb-1"><%= __('dashboard.stats_empty_title') %></h6>
                <p class="mb-0 text-muted small"><%= __('dashboard.stats_empty_text') %></p>
            </div>
            <% } %>

            <!-- align-items-start = คอลัมน์ไม่ยืดเท่ากัน (กันคอลัมน์ซ้ายโดนดึงสูงตามเมนูด่วน) -->
            <div class="row align-items-start">
                <div class="col-lg-8 mb-4">
                    <div class="card shadow mb-4">
                        <div class="card-header py-3">
                            <h6 class="m-0 font-weight-bold text-primary"><%= __('dashboard.chart_coming_title') %></h6>
                        </div>
                        <div class="card-body d-flex align-items-center justify-content-center bg-light" style="min-height: 220px;">
                            <div class="text-center text-muted px-3">
                                <i class="fas fa-chart-area fa-3x mb-3"></i>
                                <p class="mb-0"><%= __('dashboard.chart_coming_text') %></p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4 mb-4">
                    <div class="card shadow mb-4">
                        <div class="card-header py-3">
                            <h6 class="m-0 font-weight-bold text-primary"><%= __('dashboard.quick_links') %></h6>
                        </div>
                        <div class="card-body p-0">
                            <div class="dashboard-quick-links px-3 pt-3">
                            <% if (quickLinks && quickLinks.length > 0) { %>
                                <% quickLinks.forEach(function(link) { %>
                                <a href="<%= baseUrl %><%= link.path %>" class="btn <%= link.btnClass %> btn-block text-left mb-2">
                                    <i class="<%= link.icon %> mr-2"></i> <%= link.name %>
                                </a>
                                <% }); %>
                            <% } else { %>
                                <p class="text-muted small mb-0 pb-2"><%= __('dashboard.quick_links_empty') %></p>
                            <% } %>
                            </div>
                            <div class="px-3 pb-3">
                            <hr class="my-2">
                            <div class="text-center text-sm text-muted">
                                <i class="fas fa-check-circle text-success"></i> <%= __('dashboard.system_ok') %>
                            </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>
<%- include('./layouts/footer') %>
